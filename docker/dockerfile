# ── Stage 1: Builder ──────────────────────────────────────────────────────────
FROM python:3.12-slim AS builder

WORKDIR /build

# Instala dependências isoladas — camada cacheável
COPY requirements.txt .
RUN pip install --upgrade pip \
    && pip install --no-cache-dir --prefix=/install -r requirements.txt


# ── Stage 2: Runtime ─────────────────────────────────────────────────────────
FROM python:3.12-slim AS runtime

# Usuário não-root — segurança
RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser

WORKDIR /app

# Copia apenas os pacotes instalados do builder
COPY --from=builder /install /usr/local

# Copia o código da aplicação
COPY app/ ./app/

# Muda para usuário sem privilégios
USER appuser

EXPOSE 5000

# Gunicorn em produção — mais performático que o servidor dev do Flask
CMD ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "2", "--threads", "2", "app.main:create_app()"]